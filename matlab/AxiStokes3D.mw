# FORTRAN axl_coef_dlpn0_r64(int[1] nt, int[1] nq, double[nt] zr, double[nt] zi, double[nq] yr, double[nq] yi, double[nt] nxr, double[nt] nxi, double[nq] nvr, double[nq] nvi, inout double[nt,nq] C1, inout double[nt,nq] C2, inout double[nt,nq] C3a, inout double[nt,nq] C3b, inout double[nt,nq] C4);
