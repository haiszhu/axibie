n3t=3*nt; n3s=3*ns; K=zeros(n3t,n3s); Ksw=zeros(n3t,n3s);
# FORTRAN axa_kernel_slpn_r64(int[1] nt, int[1] ns, double[ns] srcr, double[ns] srcz, double[nt] tgtr, double[nt] tgtz, double[nt] tgtnr, double[nt] tgtnz, double[nt] tgtnth, int[1] m, double[1] mu, inout double[n3t,n3s] K, inout double[n3t,n3s] Ksw);
end

% ============================================================
% Laplace 0th-mode kernel-split coefficients (axissymlap_kernelsplit_mod).
% All densities REAL, nt x nq.  The normals nu=t.nx, nu'=s.nx live in the special-quad
% matrices (Sspecialquad/Dspecialquad), NOT in these coefficients.  Naming follows the
% Stokes axa_coef_* wrappers with the 0th-mode "0" marker.
% ------------------------------------------------------------
% SLP  S : C1 log, C2 smooth.
@function [C1,C2] = axl_coef_slp0_mex(nt, nq, zr, zi, yr, yi, C1, C2)
nt=double(nt); nq=double(nq);
zr=double(zr(:)); zi=double(zi(:)); yr=double(yr(:)); yi=double(yi(:));
C1=zeros(nt,nq); C2=zeros(nt,nq);
# FORTRAN axl_coef_slp0_r64(int[1] nt, int[1] nq, double[nt] zr, double[nt] zi, double[nq] yr, double[nq] yi, inout double[nt,nq] C1, inout double[nt,nq] C2);
end

% SLPn  S' : TARGET normal nxr,nxi.  C1 log, C2 smooth, C3 target-Cauchy density.
@function [C1,C2,C3] = axl_coef_slpn0_mex(nt, nq, zr, zi, yr, yi, nxr, nxi, C1, C2, C3)
nt=double(nt); nq=double(nq);
zr=double(zr(:)); zi=double(zi(:)); yr=double(yr(:)); yi=double(yi(:)); nxr=double(nxr(:)); nxi=double(nxi(:));
C1=zeros(nt,nq); C2=zeros(nt,nq); C3=zeros(nt,nq);
# FORTRAN axl_coef_slpn0_r64(int[1] nt, int[1] nq, double[nt] zr, double[nt] zi, double[nq] yr, double[nq] yi, double[nt] nxr, double[nt] nxi, inout double[nt,nq] C1, inout double[nt,nq] C2, inout double[nt,nq] C3);
end

% DLP  D : SOURCE normal nvr,nvi.  C1 log, C2 smooth, C3 source-Cauchy density.
@function [C1,C2,C3] = axl_coef_dlp0_mex(nt, nq, zr, zi, yr, yi, nvr, nvi, C1, C2, C3)
