% Helsing close-eval special quadrature: log(As), Cauchy(Ad), deriv(A1,A2), hyper(A3,A4)
@function [As, Ad, A1, A2, A3, A4] = axsq_sdspecialquad_mex(nt, zt, p, zsrc, nzsrc, wzp, za, zb, iside)
nt=double(nt); p=double(p); iside=double(iside);
zt=double(zt(:)); zsrc=double(zsrc(:)); nzsrc=double(nzsrc(:)); wzp=double(wzp(:));
za=double(za(1)); zb=double(zb(1));
As=zeros(p,nt); A1=zeros(p,nt); A2=zeros(p,nt); A3=zeros(p,nt); A4=zeros(p,nt); Ad=complex(zeros(p,nt));
# FORTRAN axsq_sdspecialquad_r64(int[1] nt, dcomplex[nt] zt, int[1] p, dcomplex[p] zsrc, dcomplex[p] nzsrc, dcomplex[p] wzp, dcomplex[1] za, dcomplex[1] zb, int[1] iside, inout double[p,nt] As, inout dcomplex[p,nt] Ad, inout double[p,nt] A1, inout double[p,nt] A2, inout double[p,nt] A3, inout double[p,nt] A4);
end

% SLP n-mode split coefs C1(log), C2(smooth)
@function [C1, C2] = axlk_slp_coef_nmode_mex(nt, tx, nq, sx, M)
nt=double(nt); nq=double(nq); M=double(M); tx=double(tx(:)); sx=double(sx(:)); Mp1=M+1; cm=nq*Mp1;
C1=zeros(nt,cm); C2=zeros(nt,cm);
# FORTRAN axlk_slp_coef_nmode_r64(int[1] nt, dcomplex[nt] tx, int[1] nq, dcomplex[nq] sx, int[1] M, inout double[nt,cm] C1, inout double[nt,cm] C2);
C1=reshape(C1,nt,nq,Mp1); C2=reshape(C2,nt,nq,Mp1);
end

