# FORTRAN axpso_lapslpn_selfsetup_r64(int[1] K, int[1] p, int[1] np, int[1] nang, int[1] pmodes, int[1] iside, int[1] iclosed, double[1] gate, dcomplex[nsp,K] sx, dcomplex[nsp,K] snx, double[nsp,K] sws, dcomplex[nsp,K] swxp, double[npp1,K] tpan, inout double[K] ntcxs, inout double[1] nbytes);
