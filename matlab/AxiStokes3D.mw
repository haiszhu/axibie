% ============================================================
% Helpers for the pure-MATLAB n-mode block builders (utils/axls_*_blockmat_nmode.m):
% the SAME compiled gauss / lagrange-interp / carrier / sdspecialquad / split-coef routines.
% ============================================================

% Gauss-Legendre nodes/weights + spectral diff matrix on [-1,1]
@function [tgl, wgl, Dgl] = axt_gauss_mex(n)
n=double(n);
tgl=zeros(n,1); wgl=zeros(n,1); Dgl=zeros(n,n);
# FORTRAN axt_gauss_r64(int[1] n, inout double[n] tgl, inout double[n] wgl, inout double[n,n] Dgl);
end

% Lagrange interpolation matrix: values on nodes xs (ns) -> targets xt (nt)
@function Mat = axt_lagrange_interp_mex(ns, xs, nt, xt)
ns=double(ns); nt=double(nt); xs=double(xs(:)); xt=double(xt(:));
Mat=zeros(nt,ns);
# FORTRAN axt_lagrange_interp_r64(int[1] ns, double[ns] xs, int[1] nt, double[nt] xt, inout double[nt,ns] Mat);
end

% Real matrix × complex vector in Fortran arithmetic: y(m) = A(m,n) * x(n).
% Matches the block builders' arithmetic (-ffp-contract=off, no FMA), unlike MATLAB BLAS.
@function y = axt_rmatcz_mex(m, n, A, x)
m=double(m); n=double(n); A=double(A); x=double(x(:));
y=complex(zeros(m,1));
# FORTRAN axt_rmatcz_r64(int[1] m, int[1] n, double[m,n] A, dcomplex[n] x, inout dcomplex[m] y);
end

% Evaluate Lagrange interpolant yout(j)=sum_k Mat(j,k)*yc(k) in Fortran arithmetic.
% xs(ns) nodes, yc(ns) complex values at nodes, xt(nt) eval points → yout(nt) complex.
% matmul done in Fortran so arithmetic matches the block builders' internal ec2=matmul(IPe2,xc).
@function yout = axt_lagrange_eval_mex(ns, xs, yc, nt, xt)
ns=double(ns); nt=double(nt); xs=double(xs(:)); xt=double(xt(:)); yc=double(yc(:));
yout=complex(zeros(nt,1));
# FORTRAN axt_lagrange_eval_r64(int[1] ns, double[ns] xs, dcomplex[ns] yc, int[1] nt, double[nt] xt, inout dcomplex[nt] yout);
end

% matrix-free 3D Stokes SLP velocity (replaces Sto3dSLPmat*[Fx;Fy;Fz]):
% u(3,nt) at targets tx(3,nt) from sources sx(3,ns), weights sw(ns), force density f(ns,3)=[fx fy fz].
@function u = axt_sto3dslp_eval_mex(tx, sx, sw, f)
nt=size(tx,2); ns=size(sx,2);
tx=double(tx); sx=double(sx); sw=double(sw(:)); f=double(f);
u=zeros(3,nt);
