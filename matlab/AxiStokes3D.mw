% AxiStokes3D.mw
% mwrap interface definitions.
%
% Build flags: mwrap -c99complex -i8 -mex
% After generation: perl -pi -e 's/_{2,}/_/g' AxiStokes3D_mex.c
%
% ============================================================
% mwrap syntax:
%   @function [inout1] = SubroutineName_mex(in1, ..., inout1)
%   % MATLAB pre-processing (reshape, double, allocate inout)
%   # FORTRAN SubroutineName(type[dims] in1, ..., inout type[dims] inout1);
%   end
%
% Convention: inout vars appear on BOTH sides of the MATLAB call (allocated in the body).
% type keywords: int, double, dcomplex ; dims: [1] scalar, [n] vector, [m,n] array (col-major).
% Complex args pass as dcomplex (NO real/imag split, -c99complex), so the MATLAB twin, the
% _mex (@function), and the _r64 (Fortran wrapper) signatures match in name and order.
%
% Prefix <pp><m>_ per NAMING.md:
%   axsk_ = axissymstok_kernelsplit_mod    axss_ = axissymstok_specialquad_mod
%   axlk_ = axissymlap_kernelsplit_mod     axls_ = axissymlap_specialquad_mod
% ============================================================
%
% Stokes specialquad block matrices.  Source = coarse panel quadrature
% (sx,snx,sws,swxp positions/normals/speed-wts/complex-wts; tpan breakpoints; sxlo/sxhi panel
% endpoints).  0th blocks: real A(2nt, 2 np p) = [Arr Arz; Azr Azz].  n-mode blocks: complex
% A(3nt, 3 np p, M+1), all modes 0..M, passed as the 2D buffer (3nt, 3 np p (M+1)) and reshaped.
% --------------------------------------------------------------------------

% SLP 0th  (no normal in the kernel; snx carried only for the unified source group).
@function A = axss_slp_blockmat_mex(nt, tx, p, np, sx, snx, sws, swxp, tpan, sxlo, sxhi, iside, iclosed, mu, A)
nt=double(nt); p=double(p); np=double(np); iside=double(iside); iclosed=double(iclosed); mu=double(mu);
tx=double(tx(:)); sx=double(sx(:)); snx=double(snx(:)); swxp=double(swxp(:)); sxlo=double(sxlo(:)); sxhi=double(sxhi(:));
sws=double(sws(:)); tpan=double(tpan(:));
nsp=p*np; npp1=np+1; r2t=2*nt; c2=2*nsp;
A=zeros(r2t,c2);
# FORTRAN axss_slp_blockmat_r64(int[1] nt, dcomplex[nt] tx, int[1] p, int[1] np, dcomplex[nsp] sx, dcomplex[nsp] snx, double[nsp] sws, dcomplex[nsp] swxp, double[npp1] tpan, dcomplex[np] sxlo, dcomplex[np] sxhi, int[1] iside, int[1] iclosed, double[1] mu, inout double[r2t,c2] A);
end

% SLP n-mode
@function A = axss_slp_blockmat_nmode_mex(nt, tx, p, np, sx, snx, sws, swxp, tpan, sxlo, sxhi, M, iside, iclosed, mu, A)
nt=double(nt); p=double(p); np=double(np); M=double(M); iside=double(iside); iclosed=double(iclosed); mu=double(mu);
tx=double(tx(:)); sx=double(sx(:)); snx=double(snx(:)); swxp=double(swxp(:)); sxlo=double(sxlo(:)); sxhi=double(sxhi(:));
sws=double(sws(:)); tpan=double(tpan(:));
nsp=p*np; npp1=np+1; Mp1=M+1; r3t=3*nt; c3m=3*nsp*Mp1;
A=zeros(r3t,c3m);
# FORTRAN axss_slp_blockmat_nmode_r64(int[1] nt, dcomplex[nt] tx, int[1] p, int[1] np, dcomplex[nsp] sx, dcomplex[nsp] snx, double[nsp] sws, dcomplex[nsp] swxp, double[npp1] tpan, dcomplex[np] sxlo, dcomplex[np] sxhi, int[1] M, int[1] iside, int[1] iclosed, double[1] mu, inout dcomplex[r3t,c3m] A);
A=reshape(A, r3t, 3*nsp, Mp1);
end

