# FORTRAN axa_kernel_dlp_r64(int[1] nt, int[1] ns, double[ns] srcr, double[ns] srcz, double[ns] srcnr, double[ns] srcnz, double[nt] tgtr, double[nt] tgtz, int[1] m, double[1] mu, inout double[n3t,n3s] K);
