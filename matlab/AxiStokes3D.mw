% Gauss-Legendre nodes/weights + spectral diff matrix on [-1,1]
@function [tgl, wgl, Dgl] = axt_gauss_mex(n)
n=double(n);
tgl=zeros(n,1); wgl=zeros(n,1); Dgl=zeros(n,n);
# FORTRAN axt_gauss_r64(int[1] n, inout double[n] tgl, inout double[n] wgl, inout double[n,n] Dgl);
end

% Lagrange interpolation matrix: values on nodes xs (ns) -> targets xt (nt)
@function Mat = axt_lagrange_interp_mex(ns, xs, nt, xt)
ns=double(ns); nt=double(nt); xs=double(xs(:)); xt=double(xt(:));
Mat=zeros(nt,ns);
# FORTRAN axt_lagrange_interp_r64(int[1] ns, double[ns] xs, int[1] nt, double[nt] xt, inout double[nt,ns] Mat);
end

% matrix-free 3D Stokes SLP velocity (replaces Sto3dSLPmat*[Fx;Fy;Fz]):
% u(3,nt) at targets tx(3,nt) from sources sx(3,ns), weights sw(ns), force density f(ns,3)=[fx fy fz].
@function u = axt_sto3dslp_eval_mex(tx, sx, sw, f)
nt=size(tx,2); ns=size(sx,2);
tx=double(tx); sx=double(sx); sw=double(sw(:)); f=double(f);
u=zeros(3,nt);
# FORTRAN axt_sto3dslp_eval_r64(int[1] nt, double[3,nt] tx, int[1] ns, double[3,ns] sx, double[ns] sw, double[ns,3] f, inout double[3,nt] u);
end

% matrix-free 3D Stokes DLP (stresslet) velocity: u(3,nt) at targets tx(3,nt) from
% sources sx(3,ns) with normals snx(3,ns), weights sw(ns), force density f(ns,3)=[fx fy fz].
@function u = axt_sto3ddlp_eval_mex(tx, sx, snx, sw, f)
nt=size(tx,2); ns=size(sx,2);
tx=double(tx); sx=double(sx); snx=double(snx); sw=double(sw(:)); f=double(f);
u=zeros(3,nt);
# FORTRAN axt_sto3ddlp_eval_r64(int[1] nt, double[3,nt] tx, int[1] ns, double[3,ns] sx, double[3,ns] snx, double[ns] sw, double[ns,3] f, inout double[3,nt] u);
end

% All-modes Q-side carrier vk=Q_{n-1/2}(chi), ve, n=0..M  (scalar chi)
@function [vk, ve] = axmg_modal_green_all_far_mex(chi, M)
chi=double(chi); M=double(M); Mp1=M+1;
vk=zeros(Mp1,1); ve=zeros(Mp1,1);
# FORTRAN axmg_modal_green_all_far_r64(double[1] chi, int[1] M, inout double[Mp1] vk, inout double[Mp1] ve);
